# =============================================================================
# mailassist — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# All variables without defaults are REQUIRED.
# =============================================================================

# ---------------------------------------------------------------------------
# Infrastructure passwords (used by docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=CHANGE_ME
VALKEY_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# APP_NAME=mailassist
# DEBUG=false
# APP_VERSION=              # Override version (default: read from pyproject.toml)
# ENABLE_CHANGELOG=true     # Show "What's New" dialog after updates

# ---------------------------------------------------------------------------
# Security — Master encryption key (min 32 characters)
# Used to encrypt IMAP/SMTP credentials at rest. Changing this invalidates
# all stored credentials. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ---------------------------------------------------------------------------
APP_SECRET_KEY=CHANGE_ME_MIN_32_CHARACTERS_LONG_SECRET

# Previous master key for graceful key rotation (optional).
# Set this to your old APP_SECRET_KEY when rotating keys.
# APP_SECRET_KEY_OLD=

# ---------------------------------------------------------------------------
# OIDC / SSO (required for the web app, optional for the worker)
# ---------------------------------------------------------------------------
OIDC_ISSUER_URL=https://your-oidc-provider.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://your-app.example.com/auth/callback
# OIDC_SCOPES=openid email profile

# ---------------------------------------------------------------------------
# CORS — Comma-separated allowed origins (empty = no cross-origin requests)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://your-app.example.com

# ---------------------------------------------------------------------------
# Database — PostgreSQL connection string (built by docker-compose.yml)
# Only override if not using the bundled postgres container.
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://mailer:password@postgres:5432/mailer

# ---------------------------------------------------------------------------
# Valkey (Redis-compatible) — connection URL (built by docker-compose.yml)
# Only override if not using the bundled valkey container.
# ---------------------------------------------------------------------------
# VALKEY_URL=redis://:password@valkey:6379/0
# VALKEY_SOCKET_TIMEOUT=5.0
# VALKEY_SOCKET_CONNECT_TIMEOUT=3.0

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
# SESSION_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
# AUTH_RATE_LIMIT=10
# API_RATE_LIMIT=100

# ---------------------------------------------------------------------------
# AI defaults
# ---------------------------------------------------------------------------
# AI_MAX_TOKENS=1024
# AI_TEMPERATURE=0.3
# AI_TIMEOUT_SECONDS=120
# AI_TOKEN_USAGE_TTL_DAYS=90
# AI_PAUSE_COOLDOWN_SECONDS=120

# ---------------------------------------------------------------------------
# Mail / IMAP
# ---------------------------------------------------------------------------
# IMAP_TIMEOUT_SECONDS=30
# IMAP_PAUSE_COOLDOWN_SECONDS=300
# MAX_EMAIL_BODY_SIZE=51200
# MAX_JOBS_PER_USER_PER_MINUTE=20

# ---------------------------------------------------------------------------
# Polling
# ---------------------------------------------------------------------------
# POLL_CONCURRENCY=5
# POLL_INITIAL_SCAN_BATCH=500

# ---------------------------------------------------------------------------
# Caching
# ---------------------------------------------------------------------------
# CONTACT_CACHE_TTL_SECONDS=3600
# IMAP_FOLDER_CACHE_TTL_SECONDS=120

# ---------------------------------------------------------------------------
# Contact sync (CardDAV)
# ---------------------------------------------------------------------------
# CONTACT_SYNC_MAX_ERRORS=10

# ---------------------------------------------------------------------------
# Database pool
# ---------------------------------------------------------------------------
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=1800

# ---------------------------------------------------------------------------
# Worker
# ---------------------------------------------------------------------------
# WORKER_MAX_JOBS=10
# WORKER_JOB_TIMEOUT=600

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------
# SCHEDULER_MAX_BATCH=500
# SCHEDULER_RESERVED_SLOTS=2
# SCHEDULER_DEFAULT_MAX_CONCURRENT=3

# ---------------------------------------------------------------------------
# Health monitoring
# ---------------------------------------------------------------------------
# HEARTBEAT_TTL_SECONDS=600
# STALE_JOB_THRESHOLD_SECONDS=660
# PROVIDER_RECOVERY_COOLDOWN_SECONDS=600
# CRON_LAST_RUN_TTL_SECONDS=3600
# PROBE_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Pipeline
# ---------------------------------------------------------------------------
# PIPELINE_PROGRESS_TTL_SECONDS=300
# APPROVAL_EXPIRY_DAYS=7

# ---------------------------------------------------------------------------
# Cron scheduling
# ---------------------------------------------------------------------------
# CRON_INTERVAL_MINUTES=10

# ---------------------------------------------------------------------------
# Draft cleanup
# ---------------------------------------------------------------------------
# DRAFT_EXPIRY_DAYS=7
# DRAFT_SENT_FOLDER_NAMES=Sent,INBOX.Sent,Sent Messages,Sent Items
# DRAFT_FOLDER_NAMES=Drafts,INBOX.Drafts,Draft
# DRAFT_LOOKBACK_DAYS=14
# DRAFT_MAX_SENT_SCAN=100

# ---------------------------------------------------------------------------
# Calendar
# ---------------------------------------------------------------------------
# ICAL_PRODUCT_ID=-//mailassist//EN

# ---------------------------------------------------------------------------
# Rules engine
# ---------------------------------------------------------------------------
# RULES_MAX_PATTERN_LENGTH=500
# RULES_MAX_TEXT_LENGTH=51200
